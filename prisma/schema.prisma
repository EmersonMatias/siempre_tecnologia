// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
///


//
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
   shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
 user
 admin
}

model User {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(150)
  email         String       @unique @db.VarChar(150)
  password      String       
  phone         String        
  city          String       
  adress        String?      @db.VarChar(250) @default("Endereço não fornecido")
  price         Int?         @default(0)
  active        Boolean      @default(false)
  account_type  Role         @default(user)
  files         User_files[]
  products      User_Products[] 
}

model User_files {
  id              Int          @id @default(autoincrement())
  original_name   String       @db.VarChar(150)
  file_name       String       @unique
  size            Int?
  user_id         Int
  url             String       
  user            User         @relation(fields: [user_id], references: [id])      
}

model User_Products {
  id              Int          @id @default(autoincrement())
  code            Int
  product         String       @db.VarChar(150)
  type            String       @db.VarChar(150)
  price           Int
  user_id         Int
  user            User         @relation(fields: [user_id], references: [id])   
}







  